{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": ".test-dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/assets.ts",
    "src/gameConfig.ts",
    "src/domain/gameTypes.ts",
    "src/levels/levelConfigs.ts",
    "src/systems/ShiftManager.ts",
    "src/systems/CustomerStateMachine.ts",
    "src/systems/GameSession.ts",
    "src/systems/PerformanceRating.ts",
    "src/systems/interactionRules.ts",
    "src/game/core/DomainEventBus.ts",
    "src/game/entities/StoreEntities.ts",
    "src/game/content/GameContent.ts",
    "src/game/content/starterMarket.ts",
    "src/game/application/CampaignRuntime.ts",
    "src/game/application/LevelRuntimeContent.ts",
    "src/game/application/ShiftRuntimeContent.ts",
    "src/game/application/RestockSceneController.ts",
    "src/game/missions/MissionTracker.ts",
    "src/game/systems/stocking/RestockWorkflow.ts",
    "src/game/interactions/RestockInteractionResolver.ts",
    "src/game/world/WorldLayout.ts",
    "src/game/world/starterMarketLayout.ts",
    "src/game/assets/AssetDescriptor.ts",
    "src/game/assets/RuntimeAssetRegistry.ts",
    "src/game/assets/starterAssetCatalogue.ts",
    "src/game/presentation/visual/StarterMarketVisualSpec.ts",
    "src/game/presentation/assets/ProductionAssetPlan.ts",
    "src/game/presentation/assets/RetainedAssetManifest.ts",
    "src/game/presentation/assets/ProductAssetResolver.ts",
    "src/game/presentation/context/StarterMarketPresentationContext.ts",
    "src/game/presentation/interactions/RestockTargetResolver.ts",
    "src/game-v2/assets/manifest.ts",
    "src/game-v2/domain/restock.ts"
  ]
}
